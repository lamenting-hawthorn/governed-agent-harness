{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-governance:contracts:v1:memory_query",
  "title": "MemoryQuery v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "tenant_id", "query_id", "scope", "query", "retrieval_profile", "budget", "allowed_categories", "correlation_id", "idempotency"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "memory_query"},
    "tenant_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "query_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "scope": {"$ref": "memory_scope.schema.json"},
    "query": {"type": "string", "minLength": 1, "maxLength": 8192},
    "retrieval_profile": {"enum": ["fast", "accurate"]},
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_records", "timeout_ms"],
      "properties": {
        "max_records": {"type": "integer", "minimum": 1, "maximum": 256},
        "timeout_ms": {"type": "integer", "minimum": 1, "maximum": 60000}
      }
    },
    "allowed_categories": {"type": "array", "minItems": 1, "maxItems": 7, "uniqueItems": true, "items": {"enum": ["fact", "preference", "episode", "procedure", "correction", "temporal", "relationship"]}},
    "temporal_bound": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": {"$ref": "definitions.schema.json#/$defs/timestamp_utc_ms"},
        "until": {"$ref": "definitions.schema.json#/$defs/timestamp_utc_ms"}
      },
      "minProperties": 1
    },
    "correlation_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "idempotency": {"$ref": "definitions.schema.json#/$defs/idempotency_binding"},
    "extensions": {"$ref": "definitions.schema.json#/$defs/extensions"}
  }
}
