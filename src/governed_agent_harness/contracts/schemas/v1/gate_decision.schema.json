{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-governance:contracts:v1:gate_decision",
  "title": "GateDecision v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "tenant_id", "gate_id", "target_scope", "proposal_refs", "evaluation_refs", "provenance_digest", "producer_version", "runtime_version", "decision", "eligibility_checks", "policy_refs", "reviewer_refs", "compatibility", "issued_at", "decision_digest"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "gate_decision"},
    "tenant_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "gate_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "target_scope": {"$ref": "memory_scope.schema.json"},
    "proposal_refs": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "evaluation_refs": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "provenance_digest": {"$ref": "definitions.schema.json#/$defs/sha256_digest"},
    "producer_version": {"$ref": "definitions.schema.json#/$defs/short_identifier"},
    "runtime_version": {"$ref": "definitions.schema.json#/$defs/short_identifier"},
    "decision": {"enum": ["approve", "reject", "review", "quarantine"]},
    "eligibility_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reproducible_evaluation", "mandatory_artifacts_present", "policy_current", "review_complete"],
      "properties": {
        "reproducible_evaluation": {"type": "boolean"},
        "mandatory_artifacts_present": {"type": "boolean"},
        "policy_current": {"type": "boolean"},
        "review_complete": {"type": "boolean"}
      }
    },
    "task_quality": {"$ref": "definitions.schema.json#/$defs/task_quality"},
    "policy_refs": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "reviewer_refs": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "compatibility": {"$ref": "definitions.schema.json#/$defs/compatibility"},
    "issued_at": {"$ref": "definitions.schema.json#/$defs/timestamp_utc_ms"},
    "decision_digest": {"$ref": "definitions.schema.json#/$defs/sha256_digest"},
    "extensions": {"$ref": "definitions.schema.json#/$defs/extensions"}
  },
  "allOf": [
    {"if": {"properties": {"decision": {"const": "approve"}}}, "then": {"required": ["task_quality"], "properties": {"eligibility_checks": {"properties": {"reproducible_evaluation": {"const": true}, "mandatory_artifacts_present": {"const": true}, "policy_current": {"const": true}, "review_complete": {"const": true}}}}}}
  ]
}
