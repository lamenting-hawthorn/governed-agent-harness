{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-governance:contracts:v1:write_receipt",
  "title": "WriteReceipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "tenant_id", "receipt_id", "request_id", "source_event_id", "resulting_revisions", "evidence_ids", "status", "idempotency", "issued_at", "receipt_digest"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "write_receipt"},
    "tenant_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "receipt_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "request_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "source_event_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "resulting_revisions": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "evidence_ids": {"type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": {"$ref": "definitions.schema.json#/$defs/uuid_v7"}},
    "status": {"enum": ["committed", "duplicate_replayed"]},
    "idempotency": {"$ref": "definitions.schema.json#/$defs/idempotency_binding"},
    "issued_at": {"$ref": "definitions.schema.json#/$defs/timestamp_utc_ms"},
    "receipt_digest": {"$ref": "definitions.schema.json#/$defs/sha256_digest"},
    "extensions": {"$ref": "definitions.schema.json#/$defs/extensions"}
  }
}
