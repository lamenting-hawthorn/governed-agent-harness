{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-governance:contracts:v1:dataset_version",
  "title": "DatasetVersion v1",
  "description": "A content-addressed dataset revision; corrections are represented by a new revision.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "tenant_id", "dataset_id", "revision", "target_scope", "lifecycle_state", "source_revisions", "consent_policy_id", "redaction_policy_id", "split_assignments", "exclusions", "producer_version", "runtime_version", "policy_refs", "reviewer_refs", "compatibility", "created_at", "manifest_digest"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "dataset_version"},
    "tenant_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "dataset_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "revision": {"type": "integer", "minimum": 1, "maximum": 2147483647},
    "target_scope": {"$ref": "memory_scope.schema.json"},
    "lifecycle_state": {"enum": ["draft", "published", "superseded", "withdrawn"]},
    "source_revisions": {"type": "array", "minItems": 1, "maxItems": 65536, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "consent_policy_id": {"$ref": "definitions.schema.json#/$defs/short_identifier"},
    "redaction_policy_id": {"$ref": "definitions.schema.json#/$defs/short_identifier"},
    "split_assignments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "validation", "test"],
      "properties": {
        "train": {"type": "array", "maxItems": 65536, "uniqueItems": true, "items": {"$ref": "definitions.schema.json#/$defs/uuid_v7"}},
        "validation": {"type": "array", "maxItems": 65536, "uniqueItems": true, "items": {"$ref": "definitions.schema.json#/$defs/uuid_v7"}},
        "test": {"type": "array", "maxItems": 65536, "uniqueItems": true, "items": {"$ref": "definitions.schema.json#/$defs/uuid_v7"}}
      }
    },
    "exclusions": {"type": "array", "maxItems": 65536, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "producer_version": {"$ref": "definitions.schema.json#/$defs/short_identifier"},
    "runtime_version": {"$ref": "definitions.schema.json#/$defs/short_identifier"},
    "policy_refs": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "reviewer_refs": {"type": "array", "maxItems": 64, "items": {"$ref": "definitions.schema.json#/$defs/record_ref"}},
    "compatibility": {"$ref": "definitions.schema.json#/$defs/compatibility"},
    "created_at": {"$ref": "definitions.schema.json#/$defs/timestamp_utc_ms"},
    "published_at": {"$ref": "definitions.schema.json#/$defs/timestamp_utc_ms"},
    "manifest_digest": {"$ref": "definitions.schema.json#/$defs/sha256_digest"},
    "extensions": {"$ref": "definitions.schema.json#/$defs/extensions"}
  },
  "allOf": [
    {"if": {"properties": {"lifecycle_state": {"const": "published"}}}, "then": {"required": ["published_at"]}}
  ]
}
