{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-governance:contracts:v1:memory_proposal",
  "title": "MemoryProposal v1",
  "description": "An inert memory change proposal. Truth confidence and task quality are separate required structures.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_type", "tenant_id", "proposal_id", "target_scope", "change_kind", "proposed_record", "evidence_spans", "producer", "truth_confidence", "task_quality", "compatibility", "expires_at", "lifecycle_state", "proposal_digest"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "memory_proposal"},
    "tenant_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "proposal_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"},
    "target_scope": {"$ref": "memory_scope.schema.json"},
    "change_kind": {"enum": ["create", "revise", "supersede", "dispute", "delete"]},
    "proposed_record": {
      "allOf": [
        {"$ref": "memory_record.schema.json"},
        {
          "required": ["lifecycle_state"],
          "properties": {"lifecycle_state": {"const": "candidate"}}
        }
      ]
    },
    "evidence_spans": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"$ref": "definitions.schema.json#/$defs/evidence_span"}},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer_id", "producer_version", "run_id"],
      "properties": {
        "producer_id": {"$ref": "definitions.schema.json#/$defs/short_identifier"},
        "producer_version": {"$ref": "definitions.schema.json#/$defs/short_identifier"},
        "run_id": {"$ref": "definitions.schema.json#/$defs/uuid_v7"}
      }
    },
    "truth_confidence": {"$ref": "definitions.schema.json#/$defs/truth_confidence"},
    "task_quality": {"$ref": "definitions.schema.json#/$defs/task_quality"},
    "compatibility": {"$ref": "definitions.schema.json#/$defs/compatibility"},
    "expires_at": {"$ref": "definitions.schema.json#/$defs/timestamp_utc_ms"},
    "lifecycle_state": {"enum": ["pending", "accepted", "rejected", "review_required", "quarantined", "expired"]},
    "proposal_digest": {"$ref": "definitions.schema.json#/$defs/sha256_digest"},
    "extensions": {"$ref": "definitions.schema.json#/$defs/extensions"}
  }
}
